# Midscene 模型配置
# ==========================================

# 方式一：本地 Ollama（免费，推荐）
MIDSCENE_MODEL_BASE_URL="http://localhost:14471/v1"
MIDSCENE_MODEL_API_KEY="ollama"
MIDSCENE_MODEL_NAME="huihui_ai/qwen3-vl-abliterated:4b-instruct"
MIDSCENE_MODEL_FAMILY="qwen3-vl"
MIDSCENE_USE_QWEN3_VL=1

# 方式二：阿里云 DashScope（需要 API Key）
# MIDSCENE_MODEL_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# MIDSCENE_MODEL_API_KEY="your-api-key-here"
# MIDSCENE_MODEL_NAME="qwen3.7-plus"
# MIDSCENE_MODEL_FAMILY="qwen3"

# 方式三：OpenAI（需要 API Key）
# MIDSCENE_MODEL_BASE_URL="https://api.openai.com/v1"
# MIDSCENE_MODEL_API_KEY="your-api-key-here"
# MIDSCENE_MODEL_NAME="gpt-4o"

# 缓存配置（可选，加速后续运行）
# ==========================================
MIDSCENE_CACHE=true
MIDSCENE_CACHE_MODE=read-write

# Wind 终端配置（可选）
# ==========================================
# 如果自动检测失败，请手动指定 Wind 终端路径
# WIND_EXECUTABLE_PATH="D:\\software\\Wind\\Wind.NET.Client\\WindNET\\bin\\windnet.exe"